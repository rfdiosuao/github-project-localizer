{
  "name": "github-project-localizer",
  "version": "1.0.0",
  "description": "AI-powered GitHub project localization tool with multi-LLM support",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:ui": "vite ./ui",
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc",
    "build:ui": "vite build ./ui",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "glob": "^10.3.0",
    "gray-matter": "^4.0.3",
    "ignore": "^5.3.0",
    "marked": "^12.0.0",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/sql.js": "^1.4.10",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^4.1.1"
  }
}
